#!/usr/bin/env python3
"""
Configure OpenCode to connect to an LLM inference provider (BYOL).
Resolves URL from CLI argument or BYOL_OPENAPI_URL env var.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from datetime import datetime
from pathlib import Path
from urllib import error, request
from urllib.parse import urlparse


def resolve_url(cli_arg: str | None) -> str | None:
    """Resolve LLM URL from CLI arg or BYOL_OPENAPI_URL env var."""
    for candidate in (cli_arg, os.environ.get("BYOL_OPENAPI_URL")):
        if not candidate:
            continue
        s = candidate.strip()
        if not s:
            continue
        parsed = urlparse(s)
        if parsed.scheme in ("http", "https") and parsed.netloc:
            return s
    return None


def get_config_path() -> Path:
    """Return path to OpenCode global config file."""
    return Path.home() / ".config" / "opencode" / "opencode.json"


def read_config(path: Path) -> dict:
    """Read existing config or return empty dict."""
    if not path.exists():
        return {}
    try:
        data = path.read_text(encoding="utf-8")
    except OSError as e:
        print(f"Error: Could not read {path}: {e!r}", file=sys.stderr)
        sys.exit(1)

    try:
        loaded = json.loads(data)
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON in {path}: {e!r}", file=sys.stderr)
        sys.exit(1)
    if not isinstance(loaded, dict):
        print(
            f"Error: Expected top-level JSON object in {path}, got {type(loaded).__name__!r}",
            file=sys.stderr,
        )
        sys.exit(1)
    return loaded


def backup_config(path: Path) -> None:
    """Create timestamped backup of config file if it exists."""
    if not path.exists():
        return
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    backup_path = path.parent / f"{path.stem}_{timestamp}{path.suffix}"
    try:
        backup_path.write_text(path.read_text(encoding="utf-8"), encoding="utf-8")
    except OSError as e:
        print(f"Warning: Could not create backup at {backup_path}: {e!r}", file=sys.stderr)


def write_config(path: Path, config: dict) -> None:
    """Write config to file with stable formatting."""
    backup_config(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(config, indent=2) + "\n", encoding="utf-8")


def show_providers_and_models(config_path: Path) -> None:
    """Display configured providers and their models."""
    if not config_path.exists():
        print(f"No config found at {config_path}")
        return
    
    config = read_config(config_path)
    provider = config.get("provider", {})
    
    if not provider:
        print("No providers configured")
        return
    
    for name, data in sorted(provider.items()):
        if isinstance(data, dict):
            models = data.get("models", {})
            model_count = len(models) if isinstance(models, dict) else 0
            base_url = data.get("options", {}).get("baseURL", "N/A")
            print(f"\n{name}:")
            print(f"  baseURL: {base_url}")
            print(f"  models: {model_count}")
        else:
            print(f"\n{name}: <non-object config>")


def validate_config(config_path: Path) -> None:
    """Validate and display configured providers and models."""
    show_providers_and_models(config_path)


def build_headers() -> dict[str, str]:
    """Build request headers for OpenAI-compatible HTTP calls."""
    headers = {"Content-Type": "application/json"}
    api_key = os.environ.get("BYOL_OPENAPI_KEY") or os.environ.get("OPENAI_API_KEY")
    if api_key:
        headers["Authorization"] = f"Bearer {api_key}"
    return headers


def request_json(
    url: str,
    *,
    method: str = "GET",
    payload: dict | None = None,
    headers: dict[str, str] | None = None,
    timeout: float = 20.0,
) -> dict:
    """Perform an HTTP request and return parsed JSON response."""
    data = None
    if payload is not None:
        data = json.dumps(payload).encode("utf-8")

    req = request.Request(
        url=url,
        data=data,
        headers=headers or {},
        method=method,
    )

    try:
        with request.urlopen(req, timeout=timeout) as resp:
            body = resp.read().decode("utf-8")
            if not body.strip():
                raise RuntimeError(f"Empty response from {url}")
            return json.loads(body)
    except error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"HTTP {exc.code} from {url}: {body!r}") from exc
    except error.URLError as exc:
        raise RuntimeError(f"Failed to reach {url}: {exc.reason!r}") from exc
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"Non-JSON response from {url}: {exc!r}") from exc


def discover_models(base_url: str, headers: dict[str, str]) -> dict[str, dict]:
    """Discover available models from /models in OpenCode config format."""
    models_url = f"{base_url.rstrip('/')}/models"
    data = request_json(models_url, headers=headers)
    models = data.get("data")
    discovered: dict[str, dict] = {}
    if isinstance(models, list):
        for item in models:
            if isinstance(item, dict):
                model_id = item.get("id")
                if isinstance(model_id, str) and model_id.strip():
                    entry: dict[str, str] = {}
                    model_name = item.get("name")
                    if isinstance(model_name, str) and model_name.strip():
                        entry["name"] = model_name.strip()
                    discovered[model_id] = entry
    if discovered:
        return discovered
    raise RuntimeError(
        "Could not discover models from /models endpoint. Check the URL and API key."
    )


def extract_message_text(response: dict) -> str:  # noqa: ANN202
    """Extract assistant text from OpenAI-compatible chat completion output.

    Args:
        response: Chat completion response dict from API.

    Returns:
        Extracted message content as string, or empty string if not found.
    """
    choices = response.get("choices")
    if not isinstance(choices, list) or not choices:
        return ""
    first = choices[0]
    if not isinstance(first, dict):
        return ""
    message = first.get("message")
    if not isinstance(message, dict):
        return ""
    content = message.get("content")
    if isinstance(content, str):
        return content.strip()
    if isinstance(content, list):
        parts: list[str] = []
        for item in content:
            if not isinstance(item, dict):
                continue
            text = item.get("text")
            if isinstance(text, str):
                parts.append(text)
        return "\n".join(parts).strip()
    return ""


def verify_inference(base_url: str, model_override: str | None = None) -> tuple[str, str, dict[str, dict]]:
    """
    Verify endpoint accessibility by running a simple inference.

    Returns (model_id, assistant_reply, discovered_models).
    """
    headers = build_headers()
    discovered_models = discover_models(base_url, headers)
    model = model_override or os.environ.get("BYOL_OPENAPI_MODEL")
    if not model:
        model = next(iter(discovered_models))

    chat_url = f"{base_url.rstrip('/')}/chat/completions"
    payload = {
        "model": model,
        "messages": [{"role": "user", "content": "what's 2+2"}],
        "temperature": 0,
        "max_tokens": 16,
    }
    response = request_json(chat_url, method="POST", payload=payload, headers=headers)
    reply = extract_message_text(response)
    return model, reply, discovered_models


def save_provider_config(config_path: Path, url: str, discovered_models: dict[str, dict]) -> None:
    """Save provider configuration to file."""
    config = read_config(config_path)

    provider = config.get("provider")
    if provider is None:
        provider = {}
        config["provider"] = provider
    elif not isinstance(provider, dict):
        print(
            "Error: Existing OpenCode config has non-object 'provider'; "
            "refusing to overwrite it.",
            file=sys.stderr,
        )
        sys.exit(1)

    byol_provider = provider.get("byol", {})
    
    options: dict[str, object] = {"baseURL": url}
    
    if isinstance(byol_provider, dict):
        existing_options = byol_provider.get("options", {})
        if isinstance(existing_options, dict):
            if "timeout" in existing_options:
                options["timeout"] = existing_options["timeout"]
            else:
                options["timeout"] = 600000
            if "chunkTimeout" in existing_options:
                options["chunkTimeout"] = existing_options["chunkTimeout"]
            else:
                options["chunkTimeout"] = 600000
    
    provider["byol"] = {
        "npm": "@ai-sdk/openai-compatible",
        "name": "BYOL",
        "options": options,
        "models": discovered_models,
    }

    write_config(config_path, config)


def interactive_setup() -> None:
    """Run interactive configuration setup."""
    print("BYOL Interactive Setup")
    print("=" * 40)

    url = input("\nEnter API base URL (e.g., https://api.example.com/v1): ").strip()
    while not resolve_url(url):
        print("Error: Invalid URL. Must be http(s):// with a host.")
        url = input("Enter API base URL: ").strip()

    api_key = os.environ.get("BYOL_OPENAPI_KEY") or os.environ.get("OPENAI_API_KEY")
    if not api_key:
        api_key_input = input("Enter API key (or press Enter to skip): ").strip()
        if api_key_input:
            os.environ["BYOL_OPENAPI_KEY"] = api_key_input

    try:
        model, answer, discovered_models = verify_inference(url)
        print("\nInference check succeeded.")
        print(f"  Model: {model}")
        print(f"  Response: {answer}")
        print(f"  Discovered models: {len(discovered_models)}")
    except RuntimeError as exc:
        print(f"\nError: Inference check failed: {exc}", file=sys.stderr)
        sys.exit(1)

    default_model = model
    
    if len(discovered_models) > 1:
        print("\nAvailable models:")
        for idx, (model_id, model_data) in enumerate(sorted(discovered_models.items()), 1):
            name = model_data.get("name", model_id)
            marker = " (default)" if model_id == default_model else ""
            print(f"  {idx}. {model_id} ({name}){marker}")
        
        while True:
            choice = input(f"\nSelect a model number (or Enter for {default_model}): ").strip()
            if not choice:
                selected_model = default_model
                os.environ["BYOL_OPENAPI_MODEL"] = selected_model
                print(f"Selected model: {selected_model}")
                break
            try:
                idx = int(choice) - 1
                if 0 <= idx < len(discovered_models):
                    selected_model = sorted(discovered_models.keys())[idx]
                    os.environ["BYOL_OPENAPI_MODEL"] = selected_model
                    print(f"Selected model: {selected_model}")
                    break
            except ValueError:
                pass
            print("Invalid selection.")

    config_path = get_config_path()
    save_provider_config(config_path, url, discovered_models)
    print(f"\nConfigured provider 'byol' at {config_path}")
    print(f"  baseURL: {url}")


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Configure OpenCode to use a BYOL LLM inference provider.",
        epilog="URL is taken from the argument, or from BYOL_OPENAPI_URL if not provided.",
    )
    parser.add_argument(
        "url",
        nargs="?",
        default=None,
        help="LLM API base URL (e.g. https://api.example.com/v1)",
    )
    parser.add_argument(
        "--validate",
        action="store_true",
        help="Show configured providers and models without making changes",
    )
    parser.add_argument(
        "-i",
        "--interactive",
        action="store_true",
        help="Run interactive configuration setup",
    )
    args = parser.parse_args()

    if args.validate:
        config_path = get_config_path()
        validate_config(config_path)
        return

    if args.interactive:
        interactive_setup()
        return

    url = resolve_url(args.url)
    if not url:
        print(
            "Error: No valid URL provided. Pass a URL as argument or set BYOL_OPENAPI_URL.",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        model, answer, discovered_models = verify_inference(url)
        print("Inference check succeeded.")
        print(f"  model: {model}")
        print("  prompt: what's 2+2")
        print(f"  response: {answer.replace(chr(10), chr(92)+chr(10))}")
        print(f"  discovered_models: {len(discovered_models)}")
    except RuntimeError as exc:
        print(f"Error: Inference pre-check failed: {exc}", file=sys.stderr)
        sys.exit(1)

    config_path = get_config_path()
    save_provider_config(config_path, url, discovered_models)
    print(f"Configured provider 'byol' at {config_path}")
    print(f"  baseURL: {url}")


if __name__ == "__main__":
    main()
